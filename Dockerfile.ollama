# --- Build stage (openab binary) ---
FROM rust:1-bookworm AS builder
WORKDIR /build
COPY Cargo.toml Cargo.lock ./
RUN mkdir src && echo 'fn main() {}' > src/main.rs && cargo build --release && rm -rf src
COPY src/ src/
RUN touch src/main.rs && cargo build --release

# --- Build stage (ollama-acp adapter) ---
FROM rust:1-bookworm AS adapter-builder
WORKDIR /adapter
COPY adapters/ollama-acp-rs/Cargo.toml ./
RUN mkdir src && echo 'fn main() {}' > src/main.rs && cargo build --release && rm -rf src
COPY adapters/ollama-acp-rs/src/ src/
RUN touch src/main.rs && cargo build --release

# --- Runtime stage (no Node.js needed — pure Rust) ---
FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

RUN useradd -m agent
ENV HOME=/home/agent
WORKDIR /home/agent

COPY --from=builder /build/target/release/openab /usr/local/bin/openab
COPY --from=adapter-builder /adapter/target/release/ollama-acp /usr/local/bin/ollama-acp

USER agent
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD pgrep -x openab || exit 1
ENTRYPOINT ["openab"]
CMD ["/etc/openab/config.toml"]
